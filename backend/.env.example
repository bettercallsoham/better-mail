# ===================================
# BullBoard Dashboard Configuration
# ===================================

# Dashboard Credentials (CHANGE THESE!)
BULLBOARD_USERNAME=admin
BULLBOARD_PASSWORD=change_this_secure_password_123

# Enable BullBoard in production (false by default for security)
BULLBOARD_ENABLED=false

# Development mode - allows access without auth (NEVER use in production!)
BULLBOARD_DEV_MODE=true

# Optional: IP Whitelist (comma-separated IPs allowed to access dashboard)
# Uncomment and add your IPs in production
# BULLBOARD_ALLOWED_IPS=192.168.1.100,10.0.0.50,your_office_ip

